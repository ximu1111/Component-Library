{
  "name": "vue3-component-library",
  "version": "1.0.0",
  "description": "Vue3 Component Library - 8 universal components with TypeScript",
  "scripts": {
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "dev": "vite --host 0.0.0.0",
    "lint": "eslint",
    "start": "serve dist -l 5000 -s",
    "test": "vitest run",
    "test:watch": "vitest",
    "ts-check": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "serve": "^14.2.6",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8",
    "vite": "^7.2.4",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  }
}
